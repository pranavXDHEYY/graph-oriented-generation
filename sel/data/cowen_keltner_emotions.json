{
  "metadata": {
    "source": "Cowen & Keltner (2017) — Self-report captures 27 distinct categories of emotion",
    "reference": "Cowen, A.S. & Keltner, D. (2017). Self-report captures 27 distinct categories of emotion bridged by continuous gradients. PNAS.",
    "description": "The 27 distinct emotional categories from Cowen & Keltner, mapped to SEL primitive seed types"
  },
  "emotions": {
    "Admiration":         {"seed_type": "social_positive",   "valence": "positive", "arousal": "medium"},
    "Adoration":          {"seed_type": "social_positive",   "valence": "positive", "arousal": "medium"},
    "Aesthetic Appreciation": {"seed_type": "aesthetic_emotion", "valence": "positive", "arousal": "medium"},
    "Amusement":          {"seed_type": "positive_emotion",  "valence": "positive", "arousal": "medium"},
    "Anger":              {"seed_type": "threat_emotion",    "valence": "negative", "arousal": "high"},
    "Anxiety":            {"seed_type": "threat_emotion",    "valence": "negative", "arousal": "high"},
    "Awe":                {"seed_type": "activation_emotion","valence": "positive", "arousal": "high"},
    "Awkwardness":        {"seed_type": "moral_emotion",     "valence": "negative", "arousal": "medium"},
    "Boredom":            {"seed_type": "confusion_emotion", "valence": "negative", "arousal": "low"},
    "Calmness":           {"seed_type": "resolution_emotion","valence": "positive", "arousal": "low"},
    "Confusion":          {"seed_type": "confusion_emotion", "valence": "negative", "arousal": "medium"},
    "Craving":            {"seed_type": "desire_emotion",    "valence": "positive", "arousal": "medium"},
    "Disgust":            {"seed_type": "social_negative",   "valence": "negative", "arousal": "medium"},
    "Empathic Pain":      {"seed_type": "empathic_emotion",  "valence": "negative", "arousal": "medium"},
    "Entrancement":       {"seed_type": "aesthetic_emotion", "valence": "positive", "arousal": "medium"},
    "Excitement":         {"seed_type": "activation_emotion","valence": "positive", "arousal": "high"},
    "Fear":               {"seed_type": "threat_emotion",    "valence": "negative", "arousal": "high"},
    "Horror":             {"seed_type": "survival_emotion",  "valence": "negative", "arousal": "very_high"},
    "Interest":           {"seed_type": "activation_emotion","valence": "positive", "arousal": "medium"},
    "Joy":                {"seed_type": "positive_emotion",  "valence": "positive", "arousal": "high", "is_attractor": true},
    "Nostalgia":          {"seed_type": "nostalgic_emotion", "valence": "mixed",    "arousal": "low"},
    "Relief":             {"seed_type": "resolution_emotion","valence": "positive", "arousal": "low"},
    "Romance":            {"seed_type": "social_positive",   "valence": "positive", "arousal": "medium"},
    "Sadness":            {"seed_type": "loss_emotion",      "valence": "negative", "arousal": "low"},
    "Satisfaction":       {"seed_type": "resolution_emotion","valence": "positive", "arousal": "low"},
    "Sexual Desire":      {"seed_type": "desire_emotion",    "valence": "positive", "arousal": "high"},
    "Sympathy":           {"seed_type": "empathic_emotion",  "valence": "mixed",    "arousal": "low"},
    "Triumph":            {"seed_type": "activation_emotion","valence": "positive", "arousal": "very_high"}
  },
  "sel_seed_type_index": {
    "loss_emotion":       ["Sadness"],
    "threat_emotion":     ["Anxiety", "Anger", "Fear"],
    "positive_emotion":   ["Joy", "Amusement"],
    "activation_emotion": ["Awe", "Excitement", "Interest", "Triumph"],
    "resolution_emotion": ["Calmness", "Relief", "Satisfaction"],
    "social_positive":    ["Admiration", "Adoration", "Romance"],
    "social_negative":    ["Disgust"],
    "moral_emotion":      ["Awkwardness"],
    "nostalgic_emotion":  ["Nostalgia"],
    "confusion_emotion":  ["Boredom", "Confusion"],
    "empathic_emotion":   ["Empathic Pain", "Sympathy"],
    "aesthetic_emotion":  ["Aesthetic Appreciation", "Entrancement"],
    "survival_emotion":   ["Horror"],
    "desire_emotion":     ["Craving", "Sexual Desire"]
  }
}
