{
  "metadata": {
    "source": "Wierzbicka Natural Semantic Metalanguage (NSM)",
    "version": "2023",
    "description": "The 65 universal semantic primitives — irreducible concepts found in all human languages",
    "reference": "Wierzbicka, A. (1972/1996). Semantics: Primes and Universals. Oxford University Press."
  },
  "categories": {
    "substantives": {
      "description": "Basic entities",
      "primitives": ["I", "YOU", "SOMEONE", "SOMETHING/THING", "PEOPLE", "BODY"]
    },
    "relational_substantives": {
      "description": "Kinds and parts",
      "primitives": ["KIND", "PART"]
    },
    "determiners": {
      "description": "Reference primitives",
      "primitives": ["THIS", "THE SAME", "OTHER/ELSE/ANOTHER"]
    },
    "quantifiers": {
      "description": "Amount primitives",
      "primitives": ["ONE", "TWO", "SOME", "ALL", "MUCH/MANY", "LITTLE/FEW"]
    },
    "evaluators_descriptors": {
      "description": "Basic evaluation",
      "primitives": ["GOOD", "BAD", "BIG", "SMALL"]
    },
    "mental_predicates": {
      "description": "Inner life",
      "primitives": ["THINK", "KNOW", "WANT", "FEEL", "SEE", "HEAR"]
    },
    "speech": {
      "description": "Communication",
      "primitives": ["SAY", "WORDS", "TRUE"]
    },
    "actions_events_movement": {
      "description": "Doing and happening",
      "primitives": ["DO", "HAPPEN", "MOVE", "TOUCH"]
    },
    "existence_possession": {
      "description": "Being and having",
      "primitives": ["BE (SOMEWHERE)", "THERE IS", "HAVE", "BE (SOMEONE/SOMETHING)"]
    },
    "life_death": {
      "description": "Existence",
      "primitives": ["LIVE", "DIE"]
    },
    "time": {
      "description": "Temporal primitives",
      "primitives": ["WHEN/TIME", "NOW", "BEFORE", "AFTER", "A LONG TIME", "A SHORT TIME", "FOR SOME TIME", "MOMENT"]
    },
    "space": {
      "description": "Spatial primitives",
      "primitives": ["WHERE/PLACE", "HERE", "ABOVE", "BELOW", "FAR", "NEAR", "SIDE", "INSIDE", "TOUCHING"]
    },
    "logical_concepts": {
      "description": "Logic operators",
      "primitives": ["NOT", "MAYBE", "CAN", "BECAUSE", "IF"]
    },
    "intensifier_augmentor": {
      "description": "Degree",
      "primitives": ["VERY", "MORE"]
    },
    "similarity": {
      "description": "Comparison",
      "primitives": ["LIKE/AS/WAY"]
    }
  },
  "sel_operator_assignments": {
    "desire":     ["WANT"],
    "temporal":   ["WHEN/TIME", "NOW", "BEFORE", "AFTER", "MOMENT"],
    "spatial":    ["WHERE/PLACE", "HERE", "FAR", "NEAR", "INSIDE"],
    "agent":      ["I", "YOU", "SOMEONE", "PEOPLE"],
    "epistemic":  ["THINK", "KNOW", "SEE", "HEAR", "FEEL"],
    "action":     ["DO", "HAPPEN", "MOVE", "TOUCH"],
    "evaluative": ["GOOD", "BAD"],
    "logical":    ["NOT", "MAYBE", "IF", "BECAUSE"],
    "intensifier":["VERY", "MORE", "ALL"],
    "existential":["LIVE", "DIE", "THERE IS"]
  }
}
